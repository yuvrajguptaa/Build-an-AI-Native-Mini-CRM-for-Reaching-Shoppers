# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Get your free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/xeno-crm?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-replace-this

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Set FRONTEND_URL to your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app
# Set BACKEND_URL to your Render deployment URL
BACKEND_URL=https://your-api.onrender.com
